# ===================================
# MONIFY — .gitignore
# ===================================

# ===== Dependencies =====
node_modules/
**/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===== Environment & Secrets (SENSITIF — JANGAN COMMIT!) =====
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env

# API Keys, Tokens, Credentials
*.key
*.pem
*.p12
*.pfx
*.crt
*.cert
secrets/
config/secrets.*

# ===== Python =====
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
apps/ai-service/venv/
apps/ai-service/.venv/
*.egg-info/
*.egg
pip-log.txt

# ===== ML Model Files (terlalu besar untuk Git) =====
*.h5
*.hdf5
*.keras
*.tflite
*.pb
*.onnx
*.pkl
*.joblib
*.pt
*.pth
*.safetensors
apps/ai-service/models/*.h5
apps/ai-service/models/*.keras
apps/ai-service/models/*.tflite

# ===== Data Files (terlalu besar untuk Git) =====
data-science/datasets/*.csv
data-science/datasets/*.xlsx
data-science/datasets/*.json
data-science/datasets/*.parquet
*.sqlite
*.db

# ===== JSON data lokal =====
apps/api/data/*.json

# ===== Build Output =====
dist/
build/
.next/
out/
*.map

# ===== Logs =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===== IDE & Editor =====
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ===== OS Files =====
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== Jupyter Notebook Checkpoints =====
.ipynb_checkpoints/

# ===== Temporary Files =====
tmp/
temp/
*.tmp
*.bak
*.cache
